# Stale Odds Hunter Configuration
# Copy to .env and fill in values

# Trading mode — paper mode requires no wallet
LIVE_TRADING_ENABLED=false

# Only needed for live trading (leave empty for paper mode)
POLYMARKET_PRIVATE_KEY=

# Logging
LOG_LEVEL=INFO

# Control API (localhost only by default)
CONTROL_API_KEY=

# Optional: override config values via env
# SOH_APP__POLL_INTERVAL_SEC=30
# SOH_APP__WS_RECONNECT_SEC=3
